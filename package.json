{
  "name": "prayerapp",
  "version": "1.5.9",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "android": "node scripts/run-android-phone.js",
    "android:rn": "react-native run-android",
    "android:fdroid": "react-native run-android --mode fdroidDebug",
    "android:assembleFdroidRelease": "cd android && ./gradlew assembleFdroidRelease",
    "android:assemblePlayRelease": "cd android && ./gradlew assemblePlayRelease",
    "android:bundlePlayRelease": "cd android && ./gradlew bundlePlayRelease",
    "android:releaseAll": "cd android && ./gradlew assemblePlayRelease assembleFdroidRelease bundlePlayRelease",
    "ios": "react-native run-ios --target PrayerApp",
    "lint": "eslint .",
    "postinstall": "patch-package",
    "start": "react-native start",
    "test": "jest",
    "generate-icons": "node scripts/generate-app-icons.js"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "adhan": "^4.4.3",
    "i18next": "^26.0.4",
    "react": "19.2.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.83.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-iap": "^12.16.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-sensors": "^7.3.6",
    "react-native-share": "^12.2.6",
    "react-native-svg": "^15.15.4",
    "react-native-view-shot": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.1",
    "@react-native/eslint-config": "0.83.1",
    "@react-native/metro-config": "0.83.1",
    "@react-native/typescript-config": "0.83.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "jimp": "^1.6.1",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
