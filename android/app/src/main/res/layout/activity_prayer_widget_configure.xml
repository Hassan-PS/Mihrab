<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_configure_background"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/widget_configure_opacity_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <SeekBar
            android:id="@+id/widget_configure_opacity_seek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="80" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/widget_configure_highlight"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <RadioGroup
            android:id="@+id/widget_configure_highlight_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/widget_configure_highlight_green"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_configure_highlight_green" />

            <RadioButton
                android:id="@+id/widget_configure_highlight_teal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_configure_highlight_teal" />

            <RadioButton
                android:id="@+id/widget_configure_highlight_blue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_configure_highlight_blue" />

            <RadioButton
                android:id="@+id/widget_configure_highlight_amber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/widget_configure_highlight_amber" />
        </RadioGroup>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/widget_configure_dynamic_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/widget_configure_system_accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_configure_system_accent_help"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/widget_configure_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/widget_configure_save" />
    </LinearLayout>
</ScrollView>
