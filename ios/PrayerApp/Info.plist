<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Prayer Times</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Prayer Times uses your approximate location to compute prayer times and Qibla direction for your area. Your coordinates are used with the prayer-time source you select in Settings (for example to request today’s schedule from that service). You can turn off GPS and enter coordinates or search for a place manually instead.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Prayer Times uses your location only to compute prayer times and Qibla—not for advertising. Location is normally used while you use the app; if the system offers broader access for the same features, it is still limited to prayer-time and Qibla functionality. You can use manual location in Settings instead of GPS.</string>
	<key>NSMotionUsageDescription</key>
	<string>Motion is used to show the Qibla compass direction.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Prayer Times needs access to your photo library to save the monthly prayer times image.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Prayer Times needs access to your photo library to save the monthly prayer times image.</string>
	<key>RCTNewArchEnabled</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<!--
	Bundled font registration — Arabic typography.

	Drop the font files into ios/PrayerApp/Resources/fonts/ and add them
	to the Xcode project's "Copy Bundle Resources" build phase. The names
	below match the font's PostScript / family name (NOT the filename),
	which is what RN reads at runtime as `fontFamily`.

	Recommended files (both have permissive licenses for app distribution):
	  * Amiri-Regular.ttf and Amiri-Bold.ttf — https://github.com/aliftype/amiri (OFL).
	    Used for Quran ayahs (FONTS.arabicQuran in src/theme/typography.ts).
	  * ScheherazadeNew-Regular.ttf — https://software.sil.org/scheherazade/ (OFL).
	    Used for general Arabic body text (FONTS.arabicBody).

	Until the .ttf files land here, RN falls back to the system Arabic
	face — which is fine for development but visually thin for ayah text.
	-->
	<key>UIAppFonts</key>
	<array>
		<string>Amiri-Regular.ttf</string>
		<string>Amiri-Bold.ttf</string>
		<string>ScheherazadeNew-Regular.ttf</string>
	</array>
</dict>
</plist>
