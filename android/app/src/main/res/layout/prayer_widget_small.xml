<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E01C1C1E"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:textColor="#9AA0A6"
        android:textSize="14sp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_refresh_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:padding="4dp"
            android:text="↻"
            android:textColor="#80FFFFFF"
            android:textSize="16sp"
            android:contentDescription="Refresh" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/widget_next_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9AA0A6"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_next_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E8EAED"
                android:textSize="44sp"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:gravity="center"
                android:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="28sp"
                android:autoSizeMaxTextSize="72sp" />

            <TextView
                android:id="@+id/widget_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9AA0A6"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#9AA0A6"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
