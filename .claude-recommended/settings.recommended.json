{
  "_comment": "RECOMMENDED settings.json content for .claude/settings.json. Manual install: copy this content over the existing .claude/settings.json after reviewing the hooks. Hooks execute arbitrary code, so Claude Code requires the user to install them manually.",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npx jest*)",
      "Bash(npx tsc*)",
      "Bash(./android/gradlew*)",
      "Bash(find src*)",
      "Bash(find ios*)",
      "Bash(find android*)",
      "Bash(find __tests__*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(wc*)",
      "Bash(sed*)",
      "Bash(cp*)",
      "Bash(gh release*)",
      "Bash(gh pr*)",
      "Bash(npm ci*)",
      "Bash(npm run*)",
      "Bash(node scripts/*)",
      "Bash(node .claude/hooks/*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/locale-parity-guard.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-reminders.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/task-context-primer.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-checks.js"
          }
        ]
      }
    ]
  }
}
