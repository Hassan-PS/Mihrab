<?xml version="1.0" encoding="utf-8"?>
<!--
  Mihrab notification status-bar icon.

  Pointed mihrab arch — the niche in a mosque's qiblah wall.
  Two diagonal lines meet at the peak (outer + inner contour) so the
  silhouette reads as the architectural mihrab shape used in Islamic
  geometry, not a rounded "U". A rounded dome was used in earlier
  versions; the pointed Gothic arch is the right reference and matches
  the launcher icon's brand mark.

  Path geometry (24×24 dp viewport):
    Outer outline (counter-clockwise from bottom-left):
      M 3,21    bottom-left of plinth
      L 3,9     up the outer-left wall
      L 12,2    diagonal up to peak
      L 21,9    diagonal down to outer-right
      L 21,21   down the outer-right wall
    Inner cutout (clockwise — even-odd fill rule):
      L 17,21   left across the bottom step
      L 17,11   up the inner-right wall
      L 12,5    diagonal up to inner peak
      L 7,11    diagonal down to inner-left
      L 7,21    down the inner-left wall
      Z         close (back to 3,21 across the base)

  Pure white fill so Android renders it correctly as a status-bar icon
  (status-bar icons are masked to alpha; any colour is replaced with
  the system's foreground tint).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M3,21 L3,9 L12,2 L21,9 L21,21 L17,21 L17,11 L12,5 L7,11 L7,21 Z" />
</vector>
