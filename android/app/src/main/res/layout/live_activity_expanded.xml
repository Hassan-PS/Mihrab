<?xml version="1.0" encoding="utf-8"?>
<!--
  Expanded RemoteViews for the prayer-countdown ongoing notification.

  Header: same headline shape as the collapsed view but with a BIG
  chronometer (32sp) on the right so the countdown reads from across the
  room.
  Progress: thick (6dp) accent-tinted bar showing fraction of time
  elapsed between previous and next prayer.
  Body: six fixed row slots (Fajr / Sunrise / Dhuhr / Asr / Maghrib /
  Isha). RemoteViews doesn't allow dynamic addView, so we declare every
  row in the XML and the Kotlin module shows/hides + populates each from
  the JSON payload. Each row carries a marker slot the module sets to a
  "›" glyph for the upcoming prayer and a blank space for the others.
  Footer: caption line for Hijri date + short location, separated by a
  middle dot when both are present.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/la_x_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/live_activity_dot" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/la_x_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:textColor="?android:attr/textColorPrimary"
                android:text="" />

            <TextView
                android:id="@+id/la_x_prayer_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="?android:attr/textColorSecondary"
                android:text="" />
        </LinearLayout>

        <Chronometer
            android:id="@+id/la_x_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="end"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ── Progress bar ───────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/la_x_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:indeterminate="false" />

    <!-- ── Divider ────────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:background="?android:attr/dividerHorizontal" />

    <!-- ── Prayer rows (6 fixed slots) ────────────────────────────── -->
    <LinearLayout
        android:id="@+id/la_x_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_0_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_0_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_0_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/la_x_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_1_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_1_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_1_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/la_x_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_2_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_2_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_2_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/la_x_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_3_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_3_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_3_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/la_x_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_4_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_4_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_4_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/la_x_row_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView android:id="@+id/la_x_row_5_marker" android:layout_width="14dp" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:text=" " />
        <TextView android:id="@+id/la_x_row_5_name" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:textSize="14sp" android:layout_marginStart="6dp" android:textColor="?android:attr/textColorSecondary" />
        <TextView android:id="@+id/la_x_row_5_time" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:fontFamily="monospace" android:textColor="?android:attr/textColorSecondary" />
    </LinearLayout>

    <!-- ── Footer caption ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/la_x_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textSize="11sp"
        android:textColor="?android:attr/textColorSecondary"
        android:text="" />
</LinearLayout>
